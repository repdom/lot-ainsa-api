<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recibo de Ingreso SMU-00115</title>
    <style>
        body {
            margin: 0;
            padding: 0;
        }

        .pagina {
            width: 21.59cm;
            height: 27.94cm;
            position: relative;
        }

        .campo {
            position: absolute;
            font-family: Arial, sans-serif;
            font-size: 12pt;
            white-space: nowrap;
        }
    </style>
</head>
<body>

<div class="pagina">
    <div class="campo" style="top: 3.50cm; left: 13.00cm;">{{.CantidadPagadaEnNumeros}}</div>
    <div class="campo" style="top: 4.50cm; left: 4.50cm;">{{.LugarYFecha}}</div>
    <div class="campo" style="top: 5.30cm; left: 4.50cm;">{{.RecibiDe}}</div>
    <div class="campo" style="top: 6.35cm; left: 8.50cm;">{{.LaCantidadDe}}</div>
    <div class="campo" style="top: 7.18cm; left: 3.87cm;">{{.Direccion}}</div>
    <div class="campo" style="top: 7.18cm; left: 15.20cm;">{{.Dui}}</div>
    <div class="campo" style="top: 7.18cm; left: 19.90cm;">{{.Nit}}</div>
    <div class="campo" style="top: 8.62cm; left: 5.52cm;">{{.ConceptoDe}}</div>
    <div class="campo" style="top: 8.55cm; left: 17.28cm;">{{.LoteN}}</div>
    <div class="campo" style="top: 8.55cm; left: 24.74cm;">{{.UbicacionDePoligono}}</div>
    <div class="campo" style="top: 11.76cm; left: 2.37cm;">{{.Efectivo}}</div>
    <div class="campo" style="top: 9.84cm; left: 8.35cm;">{{.TransferenciaID}}</div>
    <div class="campo" style="top: 9.60cm; left: 11.35cm;">{{.FechaTransferencia}}</div>
    <div class="campo" style="top: 10.40cm; left: 8.91cm;">{{.BancoT}}</div>
    <div class="campo" style="top: 10.92cm; left: 8.91cm;">{{.BancoR}}</div>
    <div class="campo" style="top: 10.89cm; left: 11.70cm;">{{.Ctan}}</div>
    <div class="campo" style="top: 9.90cm; left: 15.41cm;">{{.NumeroDeposito}}</div>
    <div class="campo" style="top: 10.84cm; left: 15.80cm;">{{.DepositoBanco}}</div>
    <div class="campo" style="top: 11.40cm; left: 3.78cm;">{{.RecibidoPor}}</div>
    <div class="campo" style="top: 12.20cm; left: 2.13cm;">{{.Firma}}</div>
    <div class="campo" style="top: 14.70cm; left: 5.50cm;">{{.ValorDelLote}}</div>
    <div class="campo" style="top: 14.70cm; left: 9.16cm;">{{.SaldoAnterior}}</div>
    <div class="campo" style="top: 14.70cm; left: 12.50cm;">{{.AbonoACapital}}</div>
    <div class="campo" style="top: 14.70cm; left: 16.50cm;">{{.InteresesNormales}}</div>
    <div class="campo" style="top: 14.70cm; left: 19.10cm;">{{.InteresesMoratorios}}</div>
    <div class="campo" style="top: 14.70cm; left: 22.80cm;">{{.SaldoActual}}</div>

</div>

</body>
</html>
