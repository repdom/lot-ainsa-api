<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recibo de Ingreso SMU-00115</title>
    <style>
        body {
            margin: 0;
            padding: 0;
        }

        .pagina {
            width: 21.59cm;
            height: 27.94cm;
            position: relative;
        }

        .campo {
            position: absolute;
            font-family: Arial, sans-serif;
            font-size: 12pt;
            white-space: nowrap;
        }
    </style>
</head>
<body>

<div class="pagina">
    <div class="campo" style="top: 3.88cm; left: 12.64cm;">{{.CantidadPagadaEnNumeros}}</div>
    <div class="campo" style="top: 4.80cm; left: 4.00cm;">{{.LugarYFecha}}</div>
    <div class="campo" style="top: 5.38cm; left: 3.63cm;">{{.RecibiDe}}</div>
    <div class="campo" style="top: 6.00cm; left: 4.47cm;">{{.LaCantidadDe}}</div>
    <div class="campo" style="top: 6.68cm; left: 3.37cm;">{{.Direccion}}</div>
    <div class="campo" style="top: 6.68cm; left: 11.70cm;">{{.Dui}}</div>
    <div class="campo" style="top: 6.68cm; left: 16.40cm;">{{.Nit}}</div>
    <div class="campo" style="top: 7.62cm; left: 4.52cm;">{{.ConceptoDe}}</div>
    <div class="campo" style="top: 7.62cm; left: 13.28cm;">{{.LoteN}}</div>
    <div class="campo" style="top: 7.62cm; left: 18.74cm;">{{.UbicacionDePoligono}}</div>
    <div class="campo" style="top: 10.26cm; left: 1.87cm;">{{.Efectivo}}</div>
    <div class="campo" style="top: 9.84cm; left: 8.35cm;">{{.TransferenciaID}}</div>
    <div class="campo" style="top: 9.60cm; left: 11.35cm;">{{.FechaTransferencia}}</div>
    <div class="campo" style="top: 10.40cm; left: 8.91cm;">{{.BancoT}}</div>
    <div class="campo" style="top: 10.92cm; left: 8.91cm;">{{.BancoR}}</div>
    <div class="campo" style="top: 10.89cm; left: 11.70cm;">{{.Ctan}}</div>
    <div class="campo" style="top: 9.90cm; left: 15.41cm;">{{.NumeroDeposito}}</div>
    <div class="campo" style="top: 10.84cm; left: 15.80cm;">{{.DepositoBanco}}</div>
    <div class="campo" style="top: 11.40cm; left: 3.78cm;">{{.RecibidoPor}}</div>
