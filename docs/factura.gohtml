    <div class="campo" style="top: 12.20cm; left: 12.50cm;">{{.InteresesNormales}}</div>
    <div class="campo" style="top: 12.20cm; left: 15.10cm;">{{.InteresesMoratorios}}</div>
    <div class="campo" style="top: 12.20cm; left: 17.80cm;">{{.SaldoActual}}</div>

</div>

</body>
</html>
